--STRING FUNCTIONS (UPPER,LOWER,CONCAT,SUBSTRING,LENGTH,TRIM,REPLACE)
SELECT 
EMP_ID,
LOWER(FIRST_NAME)AS LOWER_NAME,
UPPER(LAST_NAME)AS UPPER_NAME,
CONCAT(FIRST_NAME,'',LAST_NAME)AS FULL_NAME
FROM EMPLOYEES;

SELECT 
FIRST_NAME,
SUBSTRING(FIRST_NAME FROM 1 FOR 3)AS SHORT_NAME,
LENGTH(PHONE)AS PHONE_LENGTH,
TRIM('' FROM PHONE)AS TRIMMED_PHONE,
REPLACE(PHONE,'-','')AS CLEANED_PHONE
FROM EMPLOYEES;

--2.NUMERIC FUNCTIONS
--CALCULATE DISCOUNTED SALARY 
SELECT 
SAL_ID,
BASE_SALARY,
ROUND(BASE_SALARY * 0.90,2)AS DISCOUNTED_10_PERCENT
FROM SALARIES;
--FIND ABSOLUTE VALUES ,POWER,SQUARE ROOT
SELECT 
    emp_id,
    ABS(base_salary - 50000) AS diff_from_50k,
    POWER(base_salary, 2) AS squared_salary,
    SQRT(base_salary) AS sqrt_salary
FROM salaries;
--3.DATE FUNCTIONS
--EXTRACT YEAR,MONTH,DAY
SELECT 
EMP_ID,
EXTRACT(YEAR FROM HIRE_DATE)AS HIRE_YEAR,
EXTRACT(MONTH FROM HIRE_DATE)AS HIRE_MONTH,
EXTRACT(DAY FROM HIRE_DATE)AS HIRE_DAY
FROM EMPLOYEES;
--CALCULATE AGE
SELECT 
EMP_ID,
FIRST_NAME,
AGE(BIRTH_DATE)AS AGE 
FROM EMPLOYEES;
--RECORDS FROM LAST 30 DAYS (ATTENDANCE)
SELECT *
FROM ATTENDANCE
WHERE WORK_DATE >= CURRENT_DATE-INTERVAL'30DAYS';
--FORMAT DATES
SELECT 
EMP_ID,
TO_CHAR(HIRE_DATE,'DD-MON-YYYY')AS FORMATTED_HIRE_DATE
FROM EMPLOYEES;

--4. TYPE CASTING
--STRING -DATES
SELECT 
'2024-01-25' ::DATE AS CONVERTED_DATE;
--NUMBER - STRING
SELECT 
BASE_SALARY :: TEXT AS SALARY_AS_TEXT
FROM SALARIES;
--TIMESTAMP-DATES
SELECT 
NOW()::DATE AS TODAY_DATE;


















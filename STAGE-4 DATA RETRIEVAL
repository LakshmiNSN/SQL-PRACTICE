CREATE TABLE CUSTOMERS(
CUSTOMER_ID SERIAL PRIMARY KEY,
NAME VARCHAR(100),
EMAIL VARCHAR(50),
PHONE VARCHAR(10),
ADDRESS VARCHAR(255)
);


--QUERIES 
--AND+OR 
SELECT *
FROM PRODUCTS
WHERE CATEGORY_NAME ='MOBILES'
AND PRICE='50000';
--IN 
SELECT*
FROM PRODUCTS
WHERE CATEGORY_NAME IN ('MOBILES','ACCESSORIES','SHOPPING');
--BETWEEN 
SELECT *
FROM PRODUCTS
WHERE PRICE BETWEEN 50000 AND 70000;
--LIKE 
SELECT*
FROM PRODUCTS
WHERE CATEGORY_NAME LIKE 'A%';
--IS NULL 
SELECT *
FROM CUSTOMERS
WHERE PHONE IS NULL;

--2.PATTERN MATCHING 
--ENDING WITH @GMAIL.COM
SELECT *
FROM CUSTOMERS
WHERE EMAIL LIKE '%@GMAIL.COM';
--PRODUCTS STARTING WITH PRO
SELECT *
FROM PRODUCTS
WHERE NAME LIKE 'WAT%';
--PHONE NO PATTERN 
SELECT*
FROM CUSTOMERS
WHERE PHONE LIKE '_-_-_-';
 
--3.MULTI COLUMN SORT :SORT EMP BY DEPARTMENT ASC,SALARY DESC,NAME ASC
SELECT *
FROM PRODUCTS
ORDER BY CATEGORY_NAME ASC,PRICE DESC,NAME ASC;

--4.LIMIT & OFFSET 
SELECT * 
FROM PRODUCTS
LIMIT 10 OFFSET 20;

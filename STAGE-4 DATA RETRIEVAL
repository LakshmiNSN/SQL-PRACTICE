--1.COMPLEX WHERE :WRITE A QUERY USING AND,OR,IN,BETWEEN,LIKE ,ISNULL
CREATE TABLE PRODUCTS(
PRODCUT_ID SERIAL PRIMARY KEY,
NAME VARCHAR(100),
PRICE NUMERIC(10,2),
CATEGORY_NAME VARCHAR(100)
);
